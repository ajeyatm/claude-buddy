# API Configuration
MY_GEN_ASSIST_TOKEN="your-api-key-here"
MY_GEN_ASSIST_BASE_URL="https://your-api-base-url"
MY_GEN_ASSIST_MODEL="model-name"

# Alternative: OpenRouter Configuration
# OPENROUTER_API_KEY="your-openrouter-key"
# OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"
# OPENROUTER_MODEL="anthropic/claude-haiku-4.5"

# Agent Configuration
# Timeout for bash command execution (in seconds)
BASH_TIMEOUT_SECONDS=15

# Token Budget Configuration
# Soft limit: triggers message compaction as a precaution
SOFT_TOKEN_LIMIT=100000
# Hard limit: absolute maximum tokens allowed in a session
HARD_TOKEN_LIMIT=120000

# Message Compaction Configuration
# Number of most recent conversation turns to keep during compaction
COMPACTION_WINDOW=10

# Proxy Settings (optional)
# HTTP_PROXY="http://proxy.company.com:8080"
# HTTPS_PROXY="http://proxy.company.com:8080"
# NO_PROXY="localhost,127.0.0.1"
